{
  "name": "@sweet-player/vue",
  "version": "0.2.0",
  "description": "Vue 3 component for sweet-player",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "author": "leuvi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leuvi/sweet-player.git",
    "directory": "packages/vue"
  },
  "keywords": [
    "video",
    "player",
    "hls",
    "vue",
    "vue3"
  ],
  "dependencies": {
    "@sweet-player/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vue": "^3.5.13"
  }
}
