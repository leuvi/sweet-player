{
  "name": "@sweet-player/react",
  "version": "0.9.0",
  "description": "React component for sweet-player",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "author": "leuvi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leuvi/sweet-player.git",
    "directory": "packages/react"
  },
  "keywords": [
    "video",
    "player",
    "hls",
    "react",
    "react19"
  ],
  "dependencies": {
    "@sweet-player/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
